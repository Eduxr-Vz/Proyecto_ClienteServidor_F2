<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestión de Servicios Automotrices</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Tickets" asp-action="Index">🔧 Taller — Gestión de Servicios</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="Tickets" asp-action="Index">Tickets</a>
                <a class="nav-link" asp-controller="Tickets" asp-action="Create">Nuevo ticket</a>
                <a class="nav-link" href="/swagger" target="_blank">API (Swagger)</a>
            </div>
        </div>
    </nav>

    <main class="container pb-5">
        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="text-center text-muted small pb-3">
        Proyecto Cliente Servidor — API REST + MVC en un solo proyecto
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
