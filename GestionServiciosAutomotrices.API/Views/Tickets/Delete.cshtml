@model GestionServiciosAutomotrices.API.Models.Ticket
@{
    ViewData["Title"] = $"Eliminar {Model.Folio}";
    var esEntregado = Model.Estado == EstadoTicket.Entregado;
}

<h1 class="h3 mb-3 text-danger">Eliminar ticket</h1>

<div class="row">
    <div class="col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-body">
                <p>¿Seguro que quieres eliminar este ticket? Esta acción no se puede deshacer.</p>

                <dl class="row">
                    <dt class="col-sm-4">Folio</dt>
                    <dd class="col-sm-8">@Model.Folio</dd>

                    <dt class="col-sm-4">Vehículo</dt>
                    <dd class="col-sm-8">@Model.Vehiculo?.Marca @Model.Vehiculo?.Modelo (@Model.Vehiculo?.Placas)</dd>

                    <dt class="col-sm-4">Cliente</dt>
                    <dd class="col-sm-8">@Model.Vehiculo?.Cliente?.Nombre @Model.Vehiculo?.Cliente?.Apellidos</dd>

                    <dt class="col-sm-4">Estado</dt>
                    <dd class="col-sm-8"><partial name="_EstadoBadge" model="Model.Estado" /></dd>

                    <dt class="col-sm-4">Total</dt>
                    <dd class="col-sm-8">@Model.Total.ToString("C")</dd>
                </dl>

                @if (esEntregado)
                {
                    <div class="alert alert-warning mb-3">
                        Este ticket está <strong>Entregado</strong> y forma parte del historial del taller:
                        no se puede eliminar.
                    </div>
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver a la lista</a>
                }
                else
                {
                    <form asp-action="Delete" asp-route-id="@Model.IdTicket" method="post" class="d-inline">
                        <button type="submit" class="btn btn-danger">Sí, eliminar</button>
                    </form>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                }
            </div>
        </div>
    </div>
</div>
