@model IEnumerable<GestionServiciosAutomotrices.API.Models.Ticket>
@{
    ViewData["Title"] = "Tickets";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Tickets del taller</h1>
    <a asp-action="Create" class="btn btn-primary">+ Nuevo ticket</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Folio</th>
                    <th>Vehículo</th>
                    <th>Cliente</th>
                    <th>Mecánico</th>
                    <th>Estado</th>
                    <th class="text-end">Total</th>
                    <th>Creado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            No hay tickets registrados. Crea el primero con el botón "Nuevo ticket".
                        </td>
                    </tr>
                }
                @foreach (var t in Model)
                {
                    <tr>
                        <td><a asp-action="Details" asp-route-id="@t.IdTicket" class="fw-semibold text-decoration-none">@t.Folio</a></td>
                        <td>@t.Vehiculo?.Marca @t.Vehiculo?.Modelo <span class="text-muted small">@t.Vehiculo?.Placas</span></td>
                        <td>@t.Vehiculo?.Cliente?.Nombre @t.Vehiculo?.Cliente?.Apellidos</td>
                        <td>
                            @if (t.Mecanico != null)
                            {
                                @($"{t.Mecanico.Nombre} {t.Mecanico.Apellidos}")
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Sin asignar</span>
                            }
                        </td>
                        <td><partial name="_EstadoBadge" model="t.Estado" /></td>
                        <td class="text-end">@t.Total.ToString("C")</td>
                        <td>@t.FechaCreacion.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@t.IdTicket" class="btn btn-sm btn-outline-secondary">Editar</a>
                            <a asp-action="Delete" asp-route-id="@t.IdTicket" class="btn btn-sm btn-outline-danger">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
