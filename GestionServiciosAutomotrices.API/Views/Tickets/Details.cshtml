@model GestionServiciosAutomotrices.API.Models.Ticket
@{
    ViewData["Title"] = $"Ticket {Model.Folio}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Ticket @Model.Folio <partial name="_EstadoBadge" model="Model.Estado" /></h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.IdTicket" class="btn btn-outline-secondary">Editar</a>
        <a asp-action="Index" class="btn btn-outline-dark">Volver a la lista</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header fw-semibold">Datos generales</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Vehículo</dt>
                    <dd class="col-sm-7">@Model.Vehiculo?.Marca @Model.Vehiculo?.Modelo @Model.Vehiculo?.Anio (@Model.Vehiculo?.Placas)</dd>

                    <dt class="col-sm-5">Cliente</dt>
                    <dd class="col-sm-7">@Model.Vehiculo?.Cliente?.Nombre @Model.Vehiculo?.Cliente?.Apellidos</dd>

                    <dt class="col-sm-5">Mecánico</dt>
                    <dd class="col-sm-7">
                        @if (Model.Mecanico != null)
                        {
                            @($"{Model.Mecanico.Nombre} {Model.Mecanico.Apellidos}")
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Sin asignar</span>
                        }
                    </dd>

                    <dt class="col-sm-5">Fecha de creación</dt>
                    <dd class="col-sm-7">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-5">Entrega estimada</dt>
                    <dd class="col-sm-7">@(Model.FechaEstimadaEntrega?.ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>

                    <dt class="col-sm-5">Fecha de entrega</dt>
                    <dd class="col-sm-7">@(Model.FechaEntrega?.ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header fw-semibold">Servicios del ticket</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <tbody>
                        @if (!Model.TicketServicios.Any())
                        {
                            <tr><td class="text-muted text-center py-3">Sin servicios asociados.</td></tr>
                        }
                        @foreach (var ts in Model.TicketServicios)
                        {
                            <tr>
                                <td>@ts.Servicio?.Nombre</td>
                                <td class="text-end">@ts.PrecioAplicado.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th>Total</th>
                            <th class="text-end">@Model.Total.ToString("C")</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Descripción del problema</div>
            <div class="card-body">
                <p class="mb-0">@Model.DescripcionProblema</p>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">Observaciones del taller</div>
                <div class="card-body">
                    <p class="mb-0">@Model.Observaciones</p>
                </div>
            </div>
        </div>
    }
</div>
